      "fieldConfig": {"defaults": {"mappings": [{"type": "value", "options": {"0": {"text": "IDLE", "color": "yellow"}}}, {"type": "range", "options": {"from": 1, "to": 999999, "result": {"text": "ACTIVE", "color": "green"}}}]}},
