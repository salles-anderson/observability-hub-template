{
  "uid": "teck-home-overview",
  "title": "Teck Observability Hub — Home",
  "description": "Overview executivo — status de todos os projetos, alertas, SLOs",
  "tags": ["home", "overview", "teck"],
  "timezone": "browser",
  "refresh": "1m",
  "time": {"from": "now-24h", "to": "now"},
  "panels": [
    {
      "id": 1, "type": "text", "title": "",
      "gridPos": {"x": 0, "y": 0, "w": 24, "h": 3},
      "options": {
        "mode": "html",
        "content": "<div style='text-align:center; padding:10px 0;'><img src='/public/img/teck-logo-white.png' width='200' style='margin-bottom:8px'/><h2 style='color:#e0e0ff; margin:0; font-weight:400; letter-spacing:1px;'>Observability Hub</h2><p style='color:#90CAF9; margin:4px 0 0; font-size:12px;'>Monitoramento centralizado — 11 contas AWS</p></div>"
      }
    },
    {
      "id": 2, "type": "stat", "title": "Alertas Ativos",
      "gridPos": {"x": 0, "y": 3, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "dfayih0fcmozkc"},
      "targets": [{"refId": "A", "expr": "count(ALERTS{alertstate=\"firing\"}) or vector(0)"}],
      "fieldConfig": {"defaults": {"thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 3}]}}},
      "options": {"colorMode": "background", "graphMode": "none"}
    },
    {
      "id": 3, "type": "stat", "title": "Example API Error Rate",
      "gridPos": {"x": 6, "y": 3, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "dfayih0fcmozkc"},
      "targets": [{"refId": "A", "expr": "sli:http_error_rate:ratio_rate1h{job=\"example-api-api\"} * 100"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 1}, {"color": "red", "value": 5}]}}},
      "options": {"colorMode": "background", "graphMode": "area"}
    },
    {
      "id": 4, "type": "stat", "title": "Example API Latência P95",
      "gridPos": {"x": 12, "y": 3, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "dfayih0fcmozkc"},
      "targets": [{"refId": "A", "expr": "sli:http_latency_p95:5m{job=\"example-api-api\"} * 1000"}],
      "fieldConfig": {"defaults": {"unit": "ms", "decimals": 1, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 200}, {"color": "red", "value": 500}]}}},
      "options": {"colorMode": "background", "graphMode": "area"}
    },
    {
      "id": 5, "type": "stat", "title": "Example API Disponibilidade",
      "gridPos": {"x": 18, "y": 3, "w": 6, "h": 4},
      "datasource": {"type": "prometheus", "uid": "dfayih0fcmozkc"},
      "targets": [{"refId": "A", "expr": "sli:http_availability:ratio_rate1d{job=\"example-api-api\"} * 100"}],
      "fieldConfig": {"defaults": {"unit": "percent", "decimals": 2, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "yellow", "value": 99}, {"color": "green", "value": 99.9}]}}},
      "options": {"colorMode": "background", "graphMode": "area"}
    },
    {
      "id": 10, "type": "row", "title": "Projetos", "gridPos": {"x": 0, "y": 7, "w": 24, "h": 1}
    },
    {
      "id": 11, "type": "text", "title": "",
      "gridPos": {"x": 0, "y": 8, "w": 8, "h": 6},
      "options": {
