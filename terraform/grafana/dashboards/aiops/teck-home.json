      }
    },
    {
      "id": 12, "type": "text", "title": "",
      "gridPos": {"x": 8, "y": 8, "w": 8, "h": 6},
      "options": {
        "mode": "html",
        "content": "<div style='padding:16px;'><h3 style='color:#4FC3F7; margin:0 0 8px;'>💰 Solis</h3><p style='color:#ccc; font-size:13px; margin:4px 0 12px;'>Cessão de crédito / CCBs</p><div style='display:flex; gap:8px; margin-bottom:12px;'><a href='/dashboards/f/acct-akrk-dev/akrk-dev' style='background:#4d1a1a; color:#f87171; padding:4px 10px; border-radius:4px; font-size:11px; font-weight:600; text-decoration:none;'>PROD</a></div><ul style='color:#aaa; font-size:12px; padding-left:20px; margin:0;'><li><a href='/d/solis-prod-api-overview' style='color:#4FC3F7'>API Overview</a></li><li><a href='/d/solis-prod-ecs-metrics' style='color:#4FC3F7'>ECS Metrics</a></li><li><a href='/d/solis-prod-logs' style='color:#4FC3F7'>Logs</a></li><li><a href='/d/solis-prod-traces' style='color:#4FC3F7'>Traces</a></li></ul></div>"
      }
    },
    {
      "id": 13, "type": "text", "title": "",
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 6},
      "options": {
        "mode": "html",
        "content": "<div style='padding:16px;'><h3 style='color:#81C784; margin:0 0 12px;'>🤖 AIOps Hub</h3><p style='color:#ccc; font-size:13px; margin:4px 0;'>AI Assistant + MCP Servers</p><ul style='color:#aaa; font-size:12px; padding-left:20px; margin-top:12px;'><li><a href='/d/agent-operations' style='color:#81C784'>Agent Operations</a></li><li><a href='/d/llm-cost-center' style='color:#81C784'>LLM Cost Center</a></li><li><a href='/d/incident-overview' style='color:#81C784'>Incident Intelligence</a></li><li><a href='/d/slo-overview' style='color:#81C784'>SLO Overview</a></li><li><a href='https://assistant.observability.tower.yourorg.com.br' style='color:#81C784'>AI Assistant (Chat)</a></li></ul></div>"
      }
    },
    {
      "id": 20, "type": "row", "title": "Métricas Globais", "gridPos": {"x": 0, "y": 14, "w": 24, "h": 1}
    },
    {
      "id": 21, "type": "timeseries", "title": "Request Rate — Todos os Serviços",
      "gridPos": {"x": 0, "y": 15, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "dfayih0fcmozkc"},
      "targets": [
        {"refId": "A", "expr": "sum(sli:http_requests:rate5m{job=\"example-api-api\"})", "legendFormat": "Example API"},
        {"refId": "B", "expr": "sum(rate(http_requests_total{job=\"kong-gateway-prod\"}[5m]))", "legendFormat": "Kong Gateway"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps", "custom": {"fillOpacity": 20}}}
    },
    {
      "id": 22, "type": "timeseries", "title": "Error Rate — Todos os Serviços",
      "gridPos": {"x": 12, "y": 15, "w": 12, "h": 7},
      "datasource": {"type": "prometheus", "uid": "dfayih0fcmozkc"},
      "targets": [
        {"refId": "A", "expr": "sli:http_error_rate:ratio_rate1h{job=\"example-api-api\"} * 100", "legendFormat": "Example API"},
        {"refId": "B", "expr": "sum(rate(http_requests_total{job=\"kong-gateway-prod\",code=~\"5..\"}[5m])) / sum(rate(http_requests_total{job=\"kong-gateway-prod\"}[5m])) * 100", "legendFormat": "Kong Gateway"}
      ],
      "fieldConfig": {"defaults": {"unit": "percent", "custom": {"fillOpacity": 20}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 5}]}}}
    }
  ],
  "schemaVersion": 39
}
