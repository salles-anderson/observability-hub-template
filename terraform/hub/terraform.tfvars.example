# =============================================================================
# Observability Hub — terraform.tfvars (EXAMPLE)
# =============================================================================
# Copy this file to terraform.tfvars and fill with your values.
# NEVER commit terraform.tfvars with real values!
# =============================================================================

project     = "obs-hub"
environment = "prod"
aws_region  = "us-east-1"
account_id  = "123456789012"

# Domain
domain_name = "observability.yourdomain.com"

# ECS
ecs_cluster_name = "cluster-prod"

# Features
enable_grafana_llm = true
enable_chainlit    = true
enable_qdrant      = true
enable_agent_sdk   = true
enable_kong_ai     = false

# WAF
waf_allowed_cidrs = [
  "YOUR_OFFICE_IP/32",
  "YOUR_HOME_IP/32",
]

# API Keys (set in TFC as sensitive variables, NOT here)
# anthropic_api_key          = "sk-ant-..."
# gemini_api_key             = "AI..."
# deepseek_api_key           = "sk-..."
# github_token_obs_hub       = "ghp_..."
# grafana_service_account_token = "glsa_..."
